{
  "name": "voice-agent-kit",
  "private": true,
  "scripts": {
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck",
    "changeset": "changeset",
    "version": "changeset version",
    "validate": "bash scripts/validate-release.sh",
    "release": "changeset version && pnpm validate",
    "prepare": "husky",
    "docker:kenya": "pnpm build && cd ../Swkenya && docker compose -f docker-compose.dev.yml up --build",
    "docker:kenya:logs": "cd ../Swkenya && docker compose -f docker-compose.dev.yml logs -f"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "husky": "^9.1.7",
    "typescript": "^5.9.3"
  }
}
