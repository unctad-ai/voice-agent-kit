{
  "name": "voice-agent-kit",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint packages/*/src/",
    "changeset": "changeset",
    "version": "changeset version",
    "validate": "bash scripts/validate-release.sh",
    "release": "changeset version && pnpm validate",
    "prepare": "husky",
    "docker:kenya": "pnpm build && cd ../Swkenya && docker compose -f docker-compose.dev.yml up --build -d",
    "docker:kenya:logs": "cd ../Swkenya && docker compose -f docker-compose.dev.yml logs -f"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  }
}
