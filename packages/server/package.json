{
  "name": "@unctad-ai/voice-agent-server",
  "version": "2.0.1",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/unctad-ai/voice-agent-kit.git",
    "directory": "packages/server"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@unctad-ai/voice-agent-core": "workspace:*",
    "groq-sdk": "^1.1.1",
    "multer": "^2.1.1",
    "sharp": "^0.34.5",
    "ws": "^8.19.0"
  },
  "peerDependencies": {
    "@ai-sdk/groq": "^3.0.0",
    "ai": "^6.0.0",
    "express": ">=5",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "@ai-sdk/groq": "^3.0.29",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/ws": "^8.18.1",
    "ai": "^6.0.116",
    "express": "^5.2.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  }
}
