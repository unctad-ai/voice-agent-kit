{
  "name": "@voice-agent/server",
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "https://github.com/unctad-ai/voice-agent-kit.git",
    "directory": "packages/server"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@voice-agent/core": "workspace:*"
  },
  "peerDependencies": {
    "express": ">=5",
    "ai": "^6.0.0",
    "@ai-sdk/groq": "^3.0.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "express": "^5.2.1",
    "ai": "^6.0.100",
    "@ai-sdk/groq": "^3.0.24",
    "zod": "^3.25.76",
    "groq-sdk": "^0.37.0",
    "multer": "^2.0.2",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
