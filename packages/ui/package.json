{
  "name": "@unctad-ai/voice-agent-ui",
  "version": "5.3.0",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/unctad-ai/voice-agent-kit.git",
    "directory": "packages/ui"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@unctad-ai/voice-agent-core": "workspace:*",
    "@unctad-ai/voice-agent-registries": "workspace:*",
    "clsx": "^2.1.0",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "lucide-react": "*",
    "motion": ">=11",
    "react": ">=18",
    "react-dom": ">=18",
    "simplex-noise": "*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "simplex-noise": "^4.0.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
